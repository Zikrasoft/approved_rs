---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import TelegramCTA from '../components/TelegramCTA.astro';
import UtilityPageShell from '../components/UtilityPageShell.astro';
import { SITE_URL, SITE_NAME } from '../utils/constants';

const meta = {
  title: `Заявка принята — ${SITE_NAME}`,
  description: 'Ваша заявка принята. Свяжемся с вами в ближайшее время.',
  canonical: `${SITE_URL}/thanks/`,
};
---

<BaseLayout {...meta}>
  <UtilityPageShell minHeight="70vh" centered>
    <div>

      <div class="w-16 h-16 rounded-sm mx-auto mb-8 flex items-center justify-center bg-accent-soft border border-accent">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>

      <p class="text-xs tracking-widest uppercase mb-4 font-medium fade-up fade-up-1 text-accent">Отлично</p>
      <h1 class="font-display text-5xl font-bold mb-6 fade-up fade-up-2">Заявка принята</h1>
      <p class="text-lg mb-10 mx-auto max-w-md fade-up fade-up-3 text-muted">
        Мы получили вашу заявку и свяжемся в течение 2 часов. Если срочно — пишите в Telegram напрямую.
      </p>

      <div class="fade-up fade-up-4">
        <TelegramCTA label="Написать напрямую" />
      </div>

      <div class="mt-12 p-6 rounded-sm border fade-up fade-up-4 bg-surface border-default">
        <p class="text-sm mb-3 text-muted">Пока ждёте, посмотрите:</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/cases/"        class="text-sm font-medium no-underline text-accent">Наши кейсы →</a>
          <a href="/de/dostavka/" class="text-sm font-medium no-underline text-accent">Доставка из Германии →</a>
        </div>
      </div>

    </div>
  </UtilityPageShell>
</BaseLayout>
