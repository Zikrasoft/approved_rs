---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import TelegramCTA from '../components/TelegramCTA.astro';
import CasesGrid from '../components/CasesGrid.astro';
import SectionHeading from '../components/SectionHeading.astro';
import LeadForm from '../components/LeadForm.astro';
import { Search, Truck, Banknote, ClipboardCheck, KeyRound, Eye, Shield, MapPin } from 'lucide-astro';
import { getCollection } from 'astro:content';
import { getActiveCountries } from '../utils/geo';
import { SITE_URL, SITE_NAME } from '../utils/constants';
import StatBlock from '../components/StatBlock.astro';

const meta = {
  title: `Автоподбор и доставка авто из Европы | ${SITE_NAME}`,
  description: 'Подберём и привезём автомобиль из Германии, Испании, Сербии. Проверка, выкуп, доставка. Работаем для русскоязычных по всему миру.',
  canonical: `${SITE_URL}/`,
};

const allCases = await getCollection('cases');
const latestCases = allCases.filter(c => c.data.published).slice(0, 3);
const countries = getActiveCountries();

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE_NAME,
  description: meta.description,
  url: SITE_URL,
  serviceType: ['Автоподбор', 'Доставка автомобилей', 'Выкуп авто'],
};

const services = [
  { href: '/de/autopodbor/', Icon: Search,         title: 'Автоподбор',   desc: 'Находим и проверяем подходящие автомобили на европейских рынках' },
  { href: '/de/dostavka/',   Icon: Truck,          title: 'Доставка',     desc: 'Доставим ваш автомобиль до двери в любой стране' },
  { href: '/de/vykup/',      Icon: Banknote,       title: 'Выкуп',        desc: 'Быстрый выкуп авто на иностранных номерах' },
  { href: '/de/proverka/',   Icon: ClipboardCheck, title: 'Проверка',     desc: 'Независимая экспертиза перед покупкой у любого продавца' },
  { href: '/de/combined/',   Icon: KeyRound,       title: 'Под ключ',     desc: 'Полный цикл: подбор, проверка и доставка включены' },
];

const steps = [
  { n: '01', title: 'Заявка',   desc: 'Оставляете заявку через форму или пишете напрямую в Telegram' },
  { n: '02', title: 'Подбор',   desc: 'Ищем варианты по вашим критериям — марка, бюджет, год' },
  { n: '03', title: 'Проверка', desc: 'Независимый эксперт осматривает автомобиль перед покупкой' },
  { n: '04', title: 'Доставка', desc: 'Оформляем документы и доставляем авто к вам' },
];
---

<BaseLayout {...meta} schema={schema}>

  <!-- ─── Hero ──────────────────────────────────────────── -->
  <section class="hero-grid relative border-b overflow-hidden border-default">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 55% 60% at 10% 55%, var(--color-ambient-glow) 0%, transparent 65%), radial-gradient(ellipse 45% 40% at 90% 15%, var(--color-accent-subtle) 0%, transparent 60%);"></div>
    <span class="deco-word" style="font-size: clamp(8rem, 22vw, 20rem); bottom: -1.5rem; right: -2%; opacity: 0.9;">EUROPA</span>

    <div class="relative max-w-6xl mx-auto px-6 py-20 md:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-center">

        <div class="lg:col-span-3">
          <span class="eyebrow fade-up fade-up-1">Европейский автосервис для русскоязычных</span>
          <h1 class="font-display font-bold leading-none mb-8 fade-up fade-up-2 text-primary tracking-[-0.03em]" style="font-size: clamp(3rem, 6.5vw, 5.2rem); font-weight: 800;">
            Автоподбор<br/>
            и доставка авто<br/>
            <em class="text-accent italic">из Европы</em>
          </h1>
          <p class="text-base leading-relaxed mb-10 max-w-md fade-up fade-up-3 text-muted">
            Подберём, проверим и привезём автомобиль из Германии, Испании или Сербии. Работаем полностью удалённо — через Telegram.
          </p>
          <div class="fade-up fade-up-4">
            <TelegramCTA />
          </div>
          <div class="grid grid-cols-3 gap-6 mt-8 pt-8 border-t fade-up fade-up-5 border-default">
            <StatBlock value="200+" label="клиентов" />
            <StatBlock value="4" label="страны" />
            <StatBlock value="5 лет" label="на рынке" />
          </div>
        </div>

        <div class="lg:col-span-2 fade-up fade-up-3">
          <LeadForm />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Services ──────────────────────────────────────── -->
  <section class="border-b border-default">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12">
        <div>
          <SectionHeading title="Наши услуги" />
        </div>
        <p class="text-sm max-w-xs sm:text-right text-muted">Германия · Испания · Сербия</p>
      </div>

      <!-- Bento: featured first card spans 2 cols, rest fill naturally -->
      <div class="services-bento grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {services.map((s, i) => {
          const Icon = s.Icon;
          const idx = String(i + 1).padStart(2, '0');
          const featured = i === 0;
          return (
            <a
              href={s.href}
              class:list={[
                'service-card group flex flex-col no-underline glow-border bg-surface border border-default rounded-sm anim-inline',
                featured ? 'lg:col-span-2 p-9' : 'p-7',
              ]}
              style={`--anim-delay: ${0.08 + i * 0.08}s`}
            >
              <div class="flex items-start justify-between mb-5">
                <span class:list={['flex items-center justify-center rounded-sm shrink-0 bg-accent-subtle text-accent', featured ? 'w-12 h-12' : 'w-10 h-10']}>
                  <Icon size={featured ? 22 : 19} />
                </span>
                <span class="card-index">{idx}</span>
              </div>
              <h3 class:list={['font-display font-bold mb-2 text-primary', featured ? 'text-2xl' : 'text-xl']}>{s.title}</h3>
              <p class:list={['leading-relaxed flex-1 text-muted', featured ? 'text-base max-w-sm' : 'text-sm']}>{s.desc}</p>
              <span class="inline-flex items-center gap-1 mt-5 text-xs font-medium text-accent">
                Подробнее
                <span class="service-arrow transition-transform duration-200">→</span>
              </span>
            </a>
          );
        })}
      </div>

      <!-- Country strip -->
      <div class="flex flex-wrap gap-3 mt-4">
        {countries.map((c) => (
          <a
            href={`/${c.code}/autopodbor/`}
            class="country-pill group inline-flex items-center gap-2.5 px-4 py-2.5 rounded-sm no-underline glow-border bg-surface border border-default"
          >
            <span class="text-lg leading-none">{c.code === 'de' ? '🇩🇪' : c.code === 'rs' ? '🇷🇸' : c.code === 'es' ? '🇪🇸' : '🏳️'}</span>
            <span class="text-sm font-medium text-primary">Автоподбор в {c.nameLocative}</span>
            <span class="country-arrow text-xs text-accent transition-transform duration-200">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── How it works ──────────────────────────────────── -->
  <section class="border-b border-default">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <SectionHeading title="Как это работает" class="mb-14" />
      <div class="relative">
        <div class="hidden lg:block absolute h-px" style="top: 1.375rem; left: 2.5rem; right: 2.5rem; background: linear-gradient(90deg, transparent 0%, var(--color-accent-border) 15%, var(--color-accent-border) 85%, transparent 100%);"></div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {steps.map((step, i) => (
            <div class="anim-inline" style={`--anim-delay: ${0.1 + i * 0.1}s`}>
              <div class="step-circle">{step.n}</div>
              <h3 class="font-display text-xl font-bold mb-3 text-primary">{step.title}</h3>
              <p class="text-sm leading-relaxed text-muted">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Cases ─────────────────────────────────────────── -->
  <CasesGrid cases={latestCases} heading="Последние кейсы" headingSize="xl" viewAllHref="/cases/" />

  <!-- ─── Why us ───────────────────────────────────────── -->
  <section class="border-b border-default">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="mb-14">
        <SectionHeading title="Почему выбирают нас" />
        <p class="text-base max-w-md text-muted mt-3 leading-relaxed">
          Покупка авто удалённо вызывает вопросы. Вот как мы их снимаем.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="trust-card glow-border bg-surface border border-default rounded-sm p-8 anim-inline" style="--anim-delay: 0.08s">
          <div class="flex items-center justify-center w-11 h-11 rounded-sm mb-6 bg-accent-subtle text-accent">
            <Eye size={20} />
          </div>
          <h3 class="font-display text-xl font-bold mb-3 text-primary">Полная прозрачность</h3>
          <p class="text-sm leading-relaxed text-muted">
            Высылаем подробный чек-лист (100+ пунктов) и видео каждого нюанса: кузов, салон, ходовая. Вы видите автомобиль так, как будто стоите рядом.
          </p>
        </div>

        <div class="trust-card glow-border bg-surface border border-default rounded-sm p-8 anim-inline" style="--anim-delay: 0.16s">
          <div class="flex items-center justify-center w-11 h-11 rounded-sm mb-6 bg-accent-subtle text-accent">
            <Shield size={20} />
          </div>
          <h3 class="font-display text-xl font-bold mb-3 text-primary">Безопасность сделки</h3>
          <p class="text-sm leading-relaxed text-muted">
            Поэтапная оплата и понятные условия. Сопровождаем документы на всех этапах: оформление, растаможка, регистрация — без сюрпризов.
          </p>
        </div>

        <div class="trust-card glow-border bg-surface border border-default rounded-sm p-8 anim-inline" style="--anim-delay: 0.24s">
          <div class="flex items-center justify-center w-11 h-11 rounded-sm mb-6 bg-accent-subtle text-accent">
            <MapPin size={20} />
          </div>
          <h3 class="font-display text-xl font-bold mb-3 text-primary">Локальная экспертиза</h3>
          <p class="text-sm leading-relaxed text-muted">
            Знаем специфику каждого рынка: автобанные пробеги Германии, особенности кузова испанских авто, нюансы оформления на иностранные номера в Сербии.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── Social proof ──────────────────────────────────── -->
  <section class="border-b border-default">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="mb-14">
        <SectionHeading title="Что говорят клиенты" />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <figure class="review-card glow-border bg-surface border border-default rounded-sm p-7 flex flex-col gap-5 anim-inline" style="--anim-delay: 0.08s">
          <blockquote class="text-sm leading-relaxed text-secondary flex-1">
            «Привезли BMW 3 серии из Мюнхена в Белград. Всё чётко — от осмотра до постановки на учёт. Сэкономили кучу нервов на оформлении.»
          </blockquote>
          <figcaption class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-accent-subtle flex items-center justify-center text-accent font-display font-bold text-sm">А</div>
            <div>
              <p class="text-sm font-medium text-primary">Александр</p>
              <p class="text-xs text-muted">BMW 320d, Германия → Сербия</p>
            </div>
          </figcaption>
        </figure>

        <figure class="review-card glow-border bg-surface border border-default rounded-sm p-7 flex flex-col gap-5 anim-inline" style="--anim-delay: 0.16s">
          <blockquote class="text-sm leading-relaxed text-secondary flex-1">
            «Долго искал Skoda Octavia в хорошем состоянии. Ребята нашли вариант в Испании, проверили независимым экспертом — всё совпало с описанием.»
          </blockquote>
          <figcaption class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-accent-subtle flex items-center justify-center text-accent font-display font-bold text-sm">М</div>
            <div>
              <p class="text-sm font-medium text-primary">Михаил</p>
              <p class="text-xs text-muted">Skoda Octavia, Испания → Россия</p>
            </div>
          </figcaption>
        </figure>

        <figure class="review-card glow-border bg-surface border border-default rounded-sm p-7 flex flex-col gap-5 anim-inline" style="--anim-delay: 0.24s">
          <blockquote class="text-sm leading-relaxed text-secondary flex-1">
            «Оформление на иностранные номера казалось сложным. Команда провела через каждый шаг — и через месяц я уже ездил. Рекомендую.»
          </blockquote>
          <figcaption class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-accent-subtle flex items-center justify-center text-accent font-display font-bold text-sm">Д</div>
            <div>
              <p class="text-sm font-medium text-primary">Дмитрий</p>
              <p class="text-xs text-muted">VW Passat, Германия → Сербия</p>
            </div>
          </figcaption>
        </figure>

      </div>
    </div>
  </section>

  <!-- ─── CTA ───────────────────────────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="cta-card relative rounded-sm overflow-hidden bg-surface border border-border-strong">
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 120% at -5% 50%, var(--color-accent-soft) 0%, transparent 55%), radial-gradient(ellipse 50% 60% at 100% 100%, var(--color-ambient-glow) 0%, transparent 60%);"></div>
      <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-0">
        <div class="p-10 md:p-16">
          <span class="eyebrow">Готовы начать?</span>
          <h2 class="font-display font-bold mb-4 leading-[1.1] tracking-[-0.025em]" style="font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800;">
            Расскажите нам<br/>о своём<br/><em class="text-accent italic">автомобиле</em>
          </h2>
          <p class="text-base mb-2 max-w-sm text-muted leading-[1.7]">
            Отвечаем в течение 2 часов. Консультация бесплатна.
          </p>
          <TelegramCTA label="Написать в Telegram" />
        </div>
        <div class="cta-aside hidden lg:flex items-end justify-end p-10 md:p-16">
          <div class="grid grid-cols-2 gap-6">
            <StatBlock value="200+" label="клиентов" />
            <StatBlock value="4" label="страны" />
            <StatBlock value="5 лет" label="опыт" />
            <StatBlock value="2 ч" label="ответ" />
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .service-card:hover { background-color: var(--color-surface-2) !important; }
  .service-card:hover .service-arrow { transform: translateX(4px); }
  .country-pill:hover { background-color: var(--color-surface-2) !important; }
  .country-pill:hover .country-arrow { transform: translateX(4px); }
  .trust-card { transition: background-color 0.25s; }
  .trust-card:hover { background-color: var(--color-surface-2) !important; }
  .review-card { transition: background-color 0.25s; }
</style>
