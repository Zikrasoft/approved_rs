---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Truck, ShieldCheck, FileText, MapPin, Home, ArrowRight } from '@lucide/astro';
import LeadForm from '../../components/LeadForm.astro';
import TelegramCTA from '../../components/TelegramCTA.astro';
import CasesGrid from '../../components/CasesGrid.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getRoutePaths } from '../../utils/paths';
import { getCountry } from '../../utils/geo';
import { generateMeta } from '../../utils/seo';
import { getCollection } from 'astro:content';
import { SITE_URL, SITE_NAME } from '../../utils/constants';

export const getStaticPaths = getRoutePaths;

const { route } = Astro.params;
const { route: routeData } = Astro.props;
const fromCountry = getCountry(routeData.from)!;
const toCountry = getCountry(routeData.to)!;
const meta = generateMeta('delivery', { fromCountry, toCountry, baseUrl: SITE_URL, path: `/dostavka/${route}/` });
const cases = (await getCollection('cases')).filter(c => c.data.published && c.data.country === routeData.from && c.data.service === 'delivery').slice(0, 3);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Доставка авто из ${fromCountry.nameGenitive} в ${toCountry.nameAccusative}`,
  provider: { '@type': 'LocalBusiness', name: SITE_NAME },
  areaServed: [fromCountry.name, toCountry.name],
};
---

<BaseLayout {...meta} {schema}>
  <!-- Hero -->
  <section class="border-b border-default">
    <div class="max-w-6xl mx-auto px-6 py-16 md:py-20">
      <span class="accent-line"></span>
      <div class="flex items-center gap-3 mb-4 fade-up fade-up-1">
        <span class="text-sm font-medium text-muted">{fromCountry.name}</span>
        <ArrowRight size={14} class="text-accent" />
        <span class="text-sm font-medium text-muted">{toCountry.name}</span>
      </div>
      <h1 class="font-display text-5xl md:text-6xl font-bold mb-6 leading-tight fade-up fade-up-2">
        Доставка авто<br/>из {fromCountry.nameGenitive}<br/>
        <span class="text-accent">в {toCountry.nameAccusative}</span>
      </h1>
      <p class="text-lg max-w-xl mb-2 fade-up fade-up-3 text-muted">
        Таможенное оформление, автовоз, страховка. Срок 7–14 дней.
      </p>
      <div class="fade-up fade-up-4">
        <TelegramCTA label="Узнать стоимость" formHref="#lead-form" />
      </div>
    </div>
  </section>

  <!-- Details + Form -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div class="fade-up fade-up-1">
        <SectionHeading title="Что входит в стоимость" size="lg" class="mb-8" />
        <div class="space-y-4">
          {[
            { Icon: Truck, title: 'Транспортировка', desc: 'Перевозка автомобиля на профессиональном автовозе' },
            { Icon: ShieldCheck, title: 'Страховка груза', desc: 'Полное страхование на весь маршрут' },
            { Icon: FileText, title: 'Таможенное оформление', desc: 'Все документы и оформление под ключ' },
            { Icon: MapPin, title: 'Трекинг в реальном времени', desc: 'Отслеживайте авто на каждом этапе' },
            { Icon: Home, title: 'Доставка до двери', desc: 'Привезём прямо к вашему адресу' },
          ].map(item => (
            <div class="flex gap-4 p-4 rounded-sm border bg-surface border-default">
              <item.Icon size={20} class="shrink-0 text-accent" />
              <div>
                <p class="text-sm font-medium mb-0.5 text-primary">{item.title}</p>
                <p class="text-xs leading-relaxed text-muted">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div id="lead-form" class="fade-up fade-up-2 scroll-mt-24">
        <LeadForm service="delivery" country={routeData.from} />
      </div>
    </div>
  </section>

  <CasesGrid {cases} heading={`Кейсы: ${fromCountry.name} → ${toCountry.name}`} topBorder />
</BaseLayout>
