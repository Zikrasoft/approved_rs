---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import TelegramCTA from '../../components/TelegramCTA.astro';
import CaseCard from '../../components/CaseCard.astro';
import { getRoutePaths } from '../../utils/paths';
import { getCountry } from '../../utils/geo';
import { generateMeta } from '../../utils/seo';
import { getCollection } from 'astro:content';
import { getCasesForPage } from '../../utils/cases';
import { SITE_URL, SITE_NAME } from '../../utils/constants';

export const getStaticPaths = getRoutePaths;

const { route } = Astro.params;
const { route: routeData } = Astro.props;
const fromCountry = getCountry(routeData.from)!;
const toCountry = getCountry(routeData.to)!;
const meta = generateMeta('delivery', { fromCountry, toCountry, baseUrl: SITE_URL, path: `/dostavka/${route}/` });
const cases = getCasesForPage(await getCollection('cases'), { country: routeData.from, service: 'delivery' }).slice(0, 3);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Доставка авто из ${fromCountry.nameGenitive} в ${toCountry.name}`,
  provider: { '@type': 'LocalBusiness', name: SITE_NAME },
  areaServed: [fromCountry.name, toCountry.name],
};
---

<BaseLayout {...meta} {schema}>
  <!-- Hero -->
  <section class="border-b border-default">
    <div class="max-w-6xl mx-auto px-6 py-16 md:py-20">
      <span class="accent-line"></span>
      <div class="flex items-center gap-3 mb-4 fade-up fade-up-1">
        <span class="text-sm font-medium text-muted">{fromCountry.name}</span>
        <span class="text-accent">→</span>
        <span class="text-sm font-medium text-muted">{toCountry.name}</span>
      </div>
      <h1 class="font-display text-5xl md:text-6xl font-bold mb-6 leading-tight fade-up fade-up-2">
        Доставка авто<br/>из {fromCountry.nameGenitive}<br/>
        <span class="text-accent">в {toCountry.name}</span>
      </h1>
      <p class="text-lg max-w-xl mb-2 fade-up fade-up-3 text-muted">
        Таможенное оформление, автовоз, страховка. Срок 7–14 дней.
      </p>
      <div class="fade-up fade-up-4">
        <TelegramCTA label="Узнать стоимость" />
      </div>
    </div>
  </section>

  <!-- Details + Form -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div class="fade-up fade-up-1">
        <span class="accent-line"></span>
        <h2 class="font-display text-3xl font-bold mb-8">Что входит в стоимость</h2>
        <div class="space-y-4">
          {[
            { icon: '🚛', title: 'Транспортировка', desc: 'Перевозка автомобиля на профессиональном автовозе' },
            { icon: '🛡️', title: 'Страховка груза', desc: 'Полное страхование на весь маршрут' },
            { icon: '📑', title: 'Таможенное оформление', desc: 'Все документы и оформление под ключ' },
            { icon: '📍', title: 'Трекинг в реальном времени', desc: 'Отслеживайте авто на каждом этапе' },
            { icon: '🏠', title: 'Доставка до двери', desc: 'Привезём прямо к вашему адресу' },
          ].map(item => (
            <div class="flex gap-4 p-4 rounded-sm border bg-surface border-default">
              <span class="text-xl shrink-0">{item.icon}</span>
              <div>
                <p class="text-sm font-medium mb-0.5 text-primary">{item.title}</p>
                <p class="text-xs leading-relaxed text-muted">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="fade-up fade-up-2">
        <LeadForm service="delivery" country={routeData.from} />
      </div>
    </div>
  </section>

  <!-- Cases -->
  {cases.length > 0 && (
    <section class="border-t border-default">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <span class="accent-line"></span>
        <h2 class="font-display text-3xl mb-10">
          Кейсы: {fromCountry.name} → {toCountry.name}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {cases.map(c => <CaseCard case={c} />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
