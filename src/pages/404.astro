---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import TelegramCTA from '../components/TelegramCTA.astro';
import Button from '../components/Button.astro';
import UtilityPageShell from '../components/UtilityPageShell.astro';
import { MapPin, X } from '@lucide/astro';
import { SITE_URL, SITE_NAME } from '../utils/constants';

const meta = {
  title: `Страница не найдена — ${SITE_NAME}`,
  description: 'Запрошенная страница не существует.',
  canonical: `${SITE_URL}/404/`,
};
---

<BaseLayout {...meta}>
  <section class="hero-grid relative overflow-hidden">
    <UtilityPageShell minHeight="75vh">
      <span class="eyebrow fade-up fade-up-1">Ошибка · 404</span>

      <!-- Signature: a route that never reaches its pin -->
      <div class="route-wrap fade-up fade-up-2" aria-hidden="true">
        <svg class="route-svg" viewBox="0 0 400 140" fill="none" preserveAspectRatio="none">
          <path class="route-ghost" d="M20,102 C100,45 240,125 335,50" stroke-width="2" stroke-dasharray="1 9" stroke-linecap="round" pathLength="1" />
          <path class="route-draw"  d="M20,102 C100,45 240,125 335,50" stroke-width="2" stroke-linecap="round" pathLength="1" />
        </svg>
        <span class="route-start">
          <span class="pulse-ring ring-1"></span>
          <span class="pulse-ring ring-2"></span>
          <span class="route-dot"></span>
        </span>
        <span class="route-pin">
          <MapPin size={26} />
          <span class="route-pin-badge"><X size={10} /></span>
        </span>
      </div>

      <h1 class="font-display text-4xl font-bold mb-4 fade-up fade-up-3">Свернули не туда</h1>
      <p class="text-base text-muted max-w-sm mb-8 fade-up fade-up-4">
        Такой страницы нет — возможно, адрес изменился. Вернитесь на главную или напишите нам: подскажем, куда ехать.
      </p>

      <div class="flex flex-col sm:flex-row sm:items-center gap-4 fade-up fade-up-5">
        <Button variant="secondary" href="/" class="px-6 py-3 justify-center">
          ← На главную
        </Button>
        <TelegramCTA label="Написать нам" />
      </div>
    </UtilityPageShell>
  </section>
</BaseLayout>

<style>
  .route-wrap {
    position: relative;
    max-width: 22rem;
    height: 8.5rem;
    margin: 0.25rem 0 2rem;
  }

  .route-svg { width: 100%; height: 100%; overflow: visible; }

  .route-ghost { stroke: var(--color-border-strong); }

  .route-draw {
    stroke: var(--color-accent);
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: draw-route 0.9s 0.5s var(--ease-spring) forwards;
  }

  .route-start {
    position: absolute;
    left: 5%;
    top: 73%;
    width: 0.6rem;
    height: 0.6rem;
    translate: -50% -50%;
  }
  .route-dot {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pop-in 0.4s 0.3s var(--ease-spring) both;
  }
  .pulse-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid var(--color-accent-border);
    animation: pulse-out 2s 1.1s ease-out infinite;
  }
  .ring-2 { animation-delay: 1.8s; }

  .route-pin {
    position: absolute;
    left: 84%;
    top: 36%;
    translate: -50% -100%;
    color: var(--color-muted);
    opacity: 0;
    animation: pin-drop 0.5s 1.3s var(--ease-spring) forwards;
  }
  .route-pin-badge {
    position: absolute;
    top: -0.3rem;
    right: -0.35rem;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    border: 1.5px solid var(--color-bg);
    color: var(--color-muted);
  }
  .route-pin-badge::before {
    content: '';
    position: absolute;
    inset: -1.5px;
    border-radius: 50%;
    background: var(--color-surface-2);
    z-index: -1;
  }

  @keyframes draw-route { to { stroke-dashoffset: 0; } }
  @keyframes pop-in {
    from { opacity: 0; transform: scale(0.4); }
    to   { opacity: 1; transform: scale(1); }
  }
  @keyframes pulse-out {
    0%   { transform: scale(0.9); opacity: 0.5; }
    100% { transform: scale(2.6); opacity: 0; }
  }
  @keyframes pin-drop {
    from { opacity: 0; transform: translateY(-10px) scale(0.7); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .route-draw   { animation: none; stroke-dashoffset: 0; }
    .route-dot    { animation: none; opacity: 1; transform: none; }
    .pulse-ring   { animation: none; opacity: 0; }
    .route-pin    { animation: none; opacity: 1; }
  }
</style>
