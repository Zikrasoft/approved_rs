---
export const prerender = true;
import ServicePageLayout from '../../layouts/ServicePageLayout.astro';
import StepsList from '../../components/StepsList.astro';
import { getCountryPaths } from '../../utils/paths';
import { getCountry } from '../../utils/geo';
import { generateMeta, generateServiceSchema } from '../../utils/seo';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../utils/constants';

export const getStaticPaths = getCountryPaths;

const { country: countryCode } = Astro.params;
const country = getCountry(countryCode!)!;
const meta = generateMeta('autopodbor', { country, baseUrl: SITE_URL, path: `/${countryCode}/autopodbor/` });
const cases = (await getCollection('cases')).filter(c => c.data.published && c.data.country === countryCode && c.data.service === 'autopodbor').slice(0, 3);
const schema = generateServiceSchema(`Автоподбор в ${country.nameLocative}`, country.name, meta.canonical);
---

<ServicePageLayout
  {meta} {schema} {cases}
  title={`Автоподбор в ${country.nameLocative}`}
  description={`Подберём автомобиль в ${country.nameLocative} с полной проверкой. Сопровождение сделки, помощь с документами.`}
  ctaLabel="Оставить заявку"
  formService="autopodbor"
  currentCountry={countryCode!}
  currentService="autopodbor"
  casesHeading={`Кейсы: автоподбор в ${country.nameLocative}`}
>
  <StepsList steps={[
    { n: '01', text: 'Оставляете заявку с требованиями — бюджет, марка, пробег' },
    { n: '02', text: `Ищем варианты в ${country.nameLocative} по вашим критериям` },
    { n: '03', text: 'Независимый эксперт осматривает и проверяет автомобиль' },
    { n: '04', text: 'Сопровождаем сделку, помогаем с документами и оформлением' },
  ]} />
</ServicePageLayout>
