---
import { Send } from '@lucide/astro';
import Button from './Button.astro';
import ThreadsButton from './ThreadsButton.astro';
import { telegramLink } from '../utils/telegramLink';

interface Props {
  manager?: string;
  label?: string;
  formHref?: string;
  text?: string;
}

const {
  manager = import.meta.env.PUBLIC_TG_MANAGER!,
  label = 'Написать в Telegram',
  formHref,
  text,
} = Astro.props;
---

<div class="flex flex-wrap gap-3 my-8">
  <Button
    href={formHref ?? telegramLink(manager, text)}
    target={formHref ? undefined : '_blank'}
    rel={formHref ? undefined : 'noopener'}
    class="gap-2.5 px-6 py-3 tracking-[0.03em]"
  >
    <Send size={15} />
    {label}
  </Button>

  <ThreadsButton />
</div>
