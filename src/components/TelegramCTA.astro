---
import Button from './Button.astro';
import ThreadsButton from './ThreadsButton.astro';
interface Props {
  manager?: string;
  label?: string;
}

const {
  manager = import.meta.env.PUBLIC_TG_MANAGER!,
  label = 'Написать в Telegram',
} = Astro.props;
---

<div class="flex flex-wrap gap-3 my-8">
  <Button href={`https://t.me/${manager}`} target="_blank" rel="noopener" class="gap-2.5 px-6 py-3 tracking-[0.03em]">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.23 13.4l-2.95-.924c-.642-.204-.657-.642.136-.953l11.57-4.461c.537-.194 1.006.131.908.159z"/>
    </svg>
    {label}
  </Button>

  <ThreadsButton />
</div>
