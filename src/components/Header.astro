---
import { Menu, X, Send, Sun, Moon } from '@lucide/astro';
import SiteLogo from './SiteLogo.astro';
import Button from './Button.astro';
import LeadForm from './LeadForm.astro';
import { SERVICES } from '../utils/labels';
import { DEFAULT_COUNTRY } from '../utils/constants';
---

<header class="sticky top-0 z-50 border-b bg-header-glass border-default backdrop-blur-[16px]">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between gap-8">

    <SiteLogo />

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-7 text-sm font-sans font-normal header-nav flex-1 justify-center">
      {SERVICES.map(s => (
        <a href={`/${DEFAULT_COUNTRY}/${s.slug}/`} class="text-muted" aria-current={Astro.url.pathname.includes(`/${s.slug}/`) ? 'page' : undefined}>{s.label}</a>
      ))}
      <a href="/cases/"    class="text-muted" aria-current={Astro.url.pathname === '/cases/' ? 'page' : undefined}>Кейсы</a>
      <a href="/contacts/" class="text-muted" aria-current={Astro.url.pathname === '/contacts/' ? 'page' : undefined}>Контакты</a>
    </nav>

    <div class="flex items-center gap-2 shrink-0">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="theme-btn flex items-center justify-center w-9 h-9 rounded-sm border border-border-strong bg-surface text-muted"
        aria-label="Переключить тему"
        title="Переключить тему"
      >
        <!-- Sun: shown when dark (click → light) -->
        <span id="icon-sun" class="hidden"><Sun size={16} /></span>
        <!-- Moon: shown when light (click → dark) -->
        <span id="icon-moon"><Moon size={16} /></span>
      </button>

      <!-- CTA: always visible, text shortens below the lg breakpoint -->
      <Button type="button" data-open-lead-modal class="px-4 py-2">
        <Send size={13} />
        <span class="lg:hidden">Заявка</span>
        <span class="hidden lg:inline">Оставить заявку</span>
      </Button>

      <!-- Mobile burger -->
      <button
        id="burger"
        class="lg:hidden flex items-center justify-center w-9 h-9 rounded-sm border border-border-strong text-secondary"
        aria-label="Меню"
        aria-expanded="false"
      >
        <span id="burger-open"><Menu size={18} /></span>
        <span id="burger-close" class="hidden"><X size={18} /></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden border-t bg-header-mobile border-default"
    style="display:none"
  >
    <nav class="max-w-6xl mx-auto px-6 py-5 flex flex-col gap-0 mobile-nav">
      {SERVICES.map(s => (
        <a href={`/${DEFAULT_COUNTRY}/${s.slug}/`} class="text-secondary">{s.label}</a>
      ))}
      <a href="/cases/"    class="text-secondary">Кейсы</a>
      <a href="/contacts/" class="text-secondary">Контакты</a>
    </nav>
  </div>

  <!-- Lead form modal -->
  <dialog id="lead-modal" class="lead-modal">
    <button type="button" data-close aria-label="Закрыть" class="lead-modal-close">
      <X size={16} />
    </button>
    <LeadForm />
  </dialog>
</header>

<style>
  .header-nav a {
    position: relative;
    padding-bottom: 2px;
    transition: color 0.2s;
  }
  .header-nav a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease-spring);
  }
  .header-nav a:hover { color: var(--color-text) !important; }
  .header-nav a:hover::after { transform: scaleX(1); }
  .header-nav a[aria-current="page"] { color: var(--color-text) !important; }
  .header-nav a[aria-current="page"]::after { transform: scaleX(1); }

  .theme-btn { transition: border-color 0.2s, color 0.2s, background-color 0.2s; }
  .theme-btn:hover {
    border-color: var(--color-accent) !important;
    color: var(--color-accent) !important;
  }

  .mobile-nav a {
    display: block;
    padding: 0.85rem 0;
    font-size: 1rem;
    font-weight: 400;
    border-bottom: 1px solid var(--color-border);
    transition: color 0.2s, transform 0.2s;
  }
  .mobile-nav a:last-child { border-bottom: none; }
  .mobile-nav a:hover { color: var(--color-text) !important; transform: translateX(0.5rem); }

  #mobile-menu {
    overflow: hidden;
    clip-path: inset(0 0 100% 0);
    opacity: 0;
    transition:
      clip-path 220ms var(--ease-spring),
      opacity 180ms ease;
    pointer-events: none;
  }
  #mobile-menu.menu-open {
    clip-path: inset(0 0 0% 0);
    opacity: 1;
    pointer-events: auto;
  }

  :global(html.modal-open) {
    overflow: hidden;
    overscroll-behavior: none;
  }
  .lead-modal {
    position: relative;
    background: transparent;
    border: none;
    padding: 0;
    max-width: 26rem;
    width: 90vw;
    max-height: 90vh;
    overflow-y: auto;
    overscroll-behavior: contain;
    margin: auto;
  }
  .lead-modal::backdrop { background: rgba(13, 15, 20, 0.6); backdrop-filter: blur(4px); }
  .lead-modal-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 2px;
    border: 1px solid var(--color-border-strong);
    background: var(--color-surface);
    color: var(--color-muted);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .lead-modal-close:hover { border-color: var(--color-accent) !important; color: var(--color-accent) !important; }
</style>

<script is:inline>
  (function () {
    /* ── Theme toggle ── */
    var toggle = document.getElementById('theme-toggle');
    var sun    = document.getElementById('icon-sun');
    var moon   = document.getElementById('icon-moon');

    function updateIcons() {
      var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      if (sun)  sun.classList.toggle('hidden', !isDark);
      if (moon) moon.classList.toggle('hidden', isDark);
    }

    updateIcons();

    if (toggle) {
      toggle.addEventListener('click', function () {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
          document.documentElement.removeAttribute('data-theme');
          try { localStorage.setItem('theme', 'light'); } catch (e) {}
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          try { localStorage.setItem('theme', 'dark'); } catch (e) {}
        }
        updateIcons();
      });
    }

    /* ── Lead form modal ── */
    var leadModal = document.getElementById('lead-modal');
    if (leadModal) {
      document.querySelectorAll('[data-open-lead-modal]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          if (burger && burger.getAttribute('aria-expanded') === 'true') closeMenu();
          document.documentElement.classList.add('modal-open');
          leadModal.showModal();
        });
      });
      var leadModalClose = leadModal.querySelector('[data-close]');
      if (leadModalClose) leadModalClose.addEventListener('click', function () { leadModal.close(); });
      leadModal.addEventListener('click', function (e) {
        if (e.target === leadModal) leadModal.close();
      });
      // fires on every close path (button, backdrop click, Escape key)
      leadModal.addEventListener('close', function () {
        document.documentElement.classList.remove('modal-open');
      });
    }

    /* ── Mobile burger ── */
    var burger = document.getElementById('burger');
    var menu   = document.getElementById('mobile-menu');
    var open   = document.getElementById('burger-open');
    var close  = document.getElementById('burger-close');
    if (!burger || !menu) return;

    function openMenu() {
      menu.style.display = 'block';
      menu.offsetHeight; // force reflow so clip-path animates
      menu.classList.add('menu-open');
      burger.setAttribute('aria-expanded', 'true');
      open  && open.classList.add('hidden');
      close && close.classList.remove('hidden');
    }

    function closeMenu() {
      menu.classList.remove('menu-open');
      burger.setAttribute('aria-expanded', 'false');
      open  && open.classList.remove('hidden');
      close && close.classList.add('hidden');
      setTimeout(function () { menu.style.display = 'none'; }, 220);
    }

    burger.addEventListener('click', function () {
      burger.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
    });

    menu.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', closeMenu);
    });
  })();
</script>
