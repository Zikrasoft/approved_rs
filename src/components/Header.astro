---
import { Menu, X, Send, Sun, Moon } from 'lucide-astro';
import SiteLogo from './SiteLogo.astro';
import Button from './Button.astro';
import { SERVICES } from '../utils/labels';
import { TG_CHANNEL_FALLBACK, DEFAULT_COUNTRY } from '../utils/constants';
const TG_CHANNEL = `https://t.me/${import.meta.env.PUBLIC_TG_CHANNEL ?? TG_CHANNEL_FALLBACK}`;
---

<header class="sticky top-0 z-50 border-b bg-header-glass border-default backdrop-blur-[16px]">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between gap-8">

    <SiteLogo />

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-7 text-sm font-sans font-normal header-nav flex-1 justify-center">
      {SERVICES.map(s => (
        <a href={`/${DEFAULT_COUNTRY}/${s.slug}/`} class="text-muted">{s.label}</a>
      ))}
      <a href="/cases/"    class="text-muted">Кейсы</a>
      <a href="/contacts/" class="text-muted">Контакты</a>
    </nav>

    <div class="flex items-center gap-2 shrink-0">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="theme-btn flex items-center justify-center w-9 h-9 rounded-sm border border-border-strong bg-surface text-muted"
        aria-label="Переключить тему"
        title="Переключить тему"
      >
        <!-- Sun: shown when dark (click → light) -->
        <span id="icon-sun" class="hidden"><Sun size={16} /></span>
        <!-- Moon: shown when light (click → dark) -->
        <span id="icon-moon"><Moon size={16} /></span>
      </button>

      <!-- Desktop CTA -->
      <Button href={TG_CHANNEL} target="_blank" rel="noopener" class="hidden md:flex px-4 py-2">
        <Send size={13} />
        Telegram
      </Button>

      <!-- Mobile burger -->
      <button
        id="burger"
        class="md:hidden flex items-center justify-center w-9 h-9 rounded-sm border border-border-strong text-secondary"
        aria-label="Меню"
        aria-expanded="false"
      >
        <span id="burger-open"><Menu size={18} /></span>
        <span id="burger-close" class="hidden"><X size={18} /></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t bg-header-mobile border-default"
  >
    <nav class="max-w-6xl mx-auto px-6 py-5 flex flex-col gap-0 mobile-nav">
      {SERVICES.map(s => (
        <a href={`/${DEFAULT_COUNTRY}/${s.slug}/`} class="text-secondary">{s.label}</a>
      ))}
      <a href="/cases/"    class="text-secondary">Кейсы</a>
      <a href="/contacts/" class="text-secondary">Контакты</a>
    </nav>
    <div class="max-w-6xl mx-auto px-6 pb-6">
      <Button href={TG_CHANNEL} target="_blank" rel="noopener" class="px-5 py-2.5">
        <Send size={14} />
        Написать в Telegram
      </Button>
    </div>
  </div>
</header>

<style>
  .header-nav a {
    position: relative;
    padding-bottom: 2px;
    transition: color 0.2s;
  }
  .header-nav a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .header-nav a:hover { color: var(--color-text) !important; }
  .header-nav a:hover::after { transform: scaleX(1); }

  .theme-btn { transition: border-color 0.2s, color 0.2s, background-color 0.2s; }
  .theme-btn:hover {
    border-color: var(--color-accent) !important;
    color: var(--color-accent) !important;
  }

  .mobile-nav a {
    display: block;
    padding: 0.85rem 0;
    font-size: 1rem;
    font-weight: 400;
    border-bottom: 1px solid var(--color-border);
    transition: color 0.2s, padding-left 0.2s;
  }
  .mobile-nav a:last-child { border-bottom: none; }
  .mobile-nav a:hover { color: var(--color-text) !important; padding-left: 0.5rem; }
</style>

<script is:inline>
  (function () {
    /* ── Theme toggle ── */
    var toggle = document.getElementById('theme-toggle');
    var sun    = document.getElementById('icon-sun');
    var moon   = document.getElementById('icon-moon');

    function updateIcons() {
      var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      if (sun)  sun.classList.toggle('hidden', !isDark);
      if (moon) moon.classList.toggle('hidden', isDark);
    }

    updateIcons();

    if (toggle) {
      toggle.addEventListener('click', function () {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
          document.documentElement.removeAttribute('data-theme');
          try { localStorage.setItem('theme', 'light'); } catch (e) {}
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          try { localStorage.setItem('theme', 'dark'); } catch (e) {}
        }
        updateIcons();
      });
    }

    /* ── Mobile burger ── */
    var burger = document.getElementById('burger');
    var menu   = document.getElementById('mobile-menu');
    var open   = document.getElementById('burger-open');
    var close  = document.getElementById('burger-close');
    if (!burger || !menu) return;

    burger.addEventListener('click', function () {
      var expanded = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
      open  && open.classList.toggle('hidden');
      close && close.classList.toggle('hidden');
    });

    menu.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        menu.classList.add('hidden');
        open  && open.classList.remove('hidden');
        close && close.classList.add('hidden');
        burger.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>
