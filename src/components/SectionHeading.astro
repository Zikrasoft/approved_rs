---
interface Props {
  title: string;
  size?: 'xl' | 'lg';
  class?: string;
}

const { title, size = 'xl', class: className } = Astro.props;
---

<div class:list={['section-heading', className]}>
  <span class="accent-line"></span>
  <h2 class:list={[
    'font-display font-bold tracking-[-0.025em] leading-tight',
    size === 'xl' ? 'text-[2.75rem]' : 'text-[2.25rem]',
  ]}>{title}</h2>
</div>
