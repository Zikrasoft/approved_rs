---
import ChipLinks from './ChipLinks.astro';
import { SERVICES } from '../data/services';

interface Props {
  currentService: string;
  country: string;
}

const { currentService, country } = Astro.props;
const items = SERVICES
  .filter(s => s.slug !== currentService)
  .map(s => ({ href: `/${country}/${s.slug}/`, text: s.label }));
---

<ChipLinks label="Другие услуги:" {items} />
